# ==============================================================================
# FlowSync Backend Environment Variables Template
# Copy to .env for local development. Do NOT commit real secrets to Git.
# ==============================================================================

# Database & Redis Connection Strings
DATABASE_URL="postgresql://flowsync:flowsync_dev_pass@localhost:5433/flowsync?schema=public"
REDIS_URL="redis://localhost:6379"

# Server Configuration
PORT=3001
NODE_ENV=development

# Security & Authentication
API_KEY=dev-api-key-change-in-production
WEBHOOK_SECRET=dev-webhook-secret-change-in-production

# External API Integrations & Sandboxes
FHIR_BASE_URL=https://hapi.fhir.org/baseR4
RANDOM_USER_API_URL=https://randomuser.me/api/

# Outbound Messaging Configuration (Resend)
# Use 'mock-mode' for simulated delivery during development/testing without API keys
RESEND_API_KEY=mock-mode
RESEND_FROM_EMAIL=onboarding@resend.dev
