# FlowSync — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://flowsync:flowsync_password@localhost:5433/flowsync

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Backend Server ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Authentication ───────────────────────────────────────────────────────────
# Static API key for MVP. Change this to a strong random string in production.
API_KEY=dev-api-key-change-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# ─── External Connectors ──────────────────────────────────────────────────────
FHIR_BASE_URL=https://hapi.fhir.org/baseR4
RANDOM_USER_API_URL=https://randomuser.me/api/
WEBHOOK_SECRET=dev-webhook-secret

# Resend email API key (required for Phase 4 — messaging connector)
MESSAGING_API_KEY=re_your_resend_api_key_here
RESEND_API_KEY=re_mock_api_key_12345
RESEND_FROM_EMAIL=notifications@flowsync.dev

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
INTERNAL_API_KEY=dev-api-key-change-in-production
